{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "strict": true,
    "paths": {
      "#app/*": ["src/app/*"],
      "#apps/*": ["src/apps/*"],
      "#config/*": ["src/config/*"],
      "#core/*": ["src/core/*"],
      "#infra/*": ["src/infra/*"],
      "#modules/*": ["src/modules/*"]
    }
  }
}
